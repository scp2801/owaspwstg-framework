<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OWASP WSTG Security Report - {{ target }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', Arial, sans-serif; background: #0a0e1a; color: #e0e6f0; }
  .header { background: linear-gradient(135deg, #0d1b2a, #1a2840); padding: 40px; border-bottom: 3px solid #00d4aa; }
  .header h1 { font-size: 2em; color: #00d4aa; }
  .header p { color: #7a8fa6; margin-top: 8px; }
  .container { max-width: 1400px; margin: 0 auto; padding: 30px; }
  .meta-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin: 30px 0; }
  .meta-card { background: #1a2535; border-radius: 8px; padding: 20px; border-left: 4px solid #00d4aa; }
  .meta-card .label { color: #7a8fa6; font-size: 0.85em; text-transform: uppercase; }
  .meta-card .value { color: #fff; font-size: 1.3em; font-weight: 700; margin-top: 5px; }
  .section-title { font-size: 1.4em; color: #00d4aa; border-bottom: 2px solid #1e3040; padding-bottom: 10px; margin: 30px 0 20px; }
  .sev-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 15px; margin-bottom: 30px; }
  .sev-card { padding: 20px; border-radius: 8px; text-align: center; }
  .sev-critical { background: rgba(220,38,38,.15); border: 2px solid #dc2626; }
  .sev-high { background: rgba(234,88,12,.15); border: 2px solid #ea580c; }
  .sev-medium { background: rgba(234,179,8,.15); border: 2px solid #eab308; }
  .sev-low { background: rgba(59,130,246,.15); border: 2px solid #3b82f6; }
  .sev-card .count { font-size: 2.5em; font-weight: 700; }
  .sev-critical .count { color: #ef4444; }
  .sev-high .count { color: #f97316; }
  .sev-medium .count { color: #fbbf24; }
  .sev-low .count { color: #60a5fa; }
  .sev-card .lbl { font-size: 0.9em; text-transform: uppercase; margin-top: 5px; color: #7a8fa6; }
  .finding { background: #1a2535; border-radius: 8px; padding: 20px; margin-bottom: 15px; }
  .finding.critical { border-left: 4px solid #ef4444; }
  .finding.high { border-left: 4px solid #f97316; }
  .finding.medium { border-left: 4px solid #fbbf24; }
  .finding.low { border-left: 4px solid #60a5fa; }
  .finding-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .finding-title { font-size: 1.1em; font-weight: 600; }
  .badge { padding: 4px 12px; border-radius: 20px; font-size: 0.8em; font-weight: 600; text-transform: uppercase; }
  .badge.critical { background: #7f1d1d; color: #fca5a5; }
  .badge.high { background: #7c2d12; color: #fdba74; }
  .badge.medium { background: #713f12; color: #fde68a; }
  .badge.low { background: #1e3a5f; color: #93c5fd; }
  .evidence-box { background: #0a0e1a; border-radius: 6px; padding: 12px; margin-top: 10px; font-family: monospace; font-size: 0.85em; color: #7dd3fc; white-space: pre-wrap; max-height: 120px; overflow-y: auto; }
  .rec-box { background: #0f2718; border-radius: 6px; padding: 12px; margin-top: 8px; color: #86efac; }
  table { width: 100%; border-collapse: collapse; }
  th { background: #0f2030; color: #00d4aa; padding: 10px; text-align: left; font-size: 0.85em; }
  td { padding: 10px; border-bottom: 1px solid #1e3040; font-size: 0.9em; }
  .status-pass { color: #4ade80; font-weight: 600; }
  .status-fail { color: #f87171; font-weight: 600; }
  .status-review { color: #fbbf24; font-weight: 600; }
  .status-na { color: #6b7280; }
  .footer { text-align: center; padding: 30px; color: #4a5568; border-top: 2px solid #1e3040; margin-top: 40px; }
  .disclaimer { background: rgba(234,88,12,.1); border: 1px solid #ea580c; border-radius: 8px; padding: 15px; margin: 20px 0; color: #fdba74; }
</style>
</head>
<body>
<div class="header">
  <h1>🔒 Security Assessment Report</h1>
  <p>OWASP Web Security Testing Guide (WSTG) v4.2 — Automated Analysis</p>
</div>

<div class="container">
  <div class="disclaimer">
    ⚠️ <strong>Legal Disclaimer:</strong> This report is for authorized security testing only. All findings must be responsibly disclosed.
  </div>

  <div class="meta-grid">
    <div class="meta-card"><div class="label">Target</div><div class="value">{{ target }}</div></div>
    <div class="meta-card"><div class="label">Scan Date</div><div class="value">{{ scan_date }}</div></div>
    <div class="meta-card"><div class="label">Scan ID</div><div class="value" style="font-size:1em">{{ scan_id }}</div></div>
    <div class="meta-card"><div class="label">Duration</div><div class="value">{{ duration }}s</div></div>
  </div>

  <h2 class="section-title">📊 Executive Summary</h2>
  <div class="sev-grid">
    <div class="sev-card sev-critical"><div class="count">{{ critical_count }}</div><div class="lbl">Critical</div></div>
    <div class="sev-card sev-high"><div class="count">{{ high_count }}</div><div class="lbl">High</div></div>
    <div class="sev-card sev-medium"><div class="count">{{ medium_count }}</div><div class="lbl">Medium</div></div>
    <div class="sev-card sev-low"><div class="count">{{ low_count }}</div><div class="lbl">Low</div></div>
  </div>

  <h2 class="section-title">🐛 Vulnerability Findings</h2>
  {% if vulnerabilities %}
    {% for v in vulnerabilities %}
    <div class="finding {{ v.severity|lower }}">
      <div class="finding-hdr">
        <span class="finding-title">{{ v.name }}</span>
        <span class="badge {{ v.severity|lower }}">{{ v.severity }}</span>
      </div>
      <div style="margin:8px 0;color:#7a8fa6;font-size:0.9em">
        WSTG: {{ v.wstg_id }} | CWE: {{ v.cwe }} | CVSS: {{ v.cvss }}
      </div>
      <div><strong>URL:</strong> <span style="color:#7dd3fc">{{ v.url }}</span></div>
      <div style="margin-top:8px">{{ v.description }}</div>
      <div class="evidence-box">{{ v.evidence }}</div>
      <div class="rec-box">💡 {{ v.recommendation }}</div>
    </div>
    {% endfor %}
  {% else %}
    <p style="color:#4ade80">✓ No exploitable vulnerabilities detected in automated scan.</p>
  {% endif %}

  <h2 class="section-title">📋 OWASP WSTG Checklist</h2>
  <table>
    <tr><th>WSTG ID</th><th>Category</th><th>Test Name</th><th>Status</th><th>Severity</th></tr>
    {% for item in checklist %}
    <tr>
      <td><strong>{{ item.id }}</strong></td>
      <td>{{ item.category }}</td>
      <td>{{ item.name }}</td>
      <td class="status-{{ item.status|lower }}">{{ item.status }}</td>
      <td>{{ item.severity }}</td>
    </tr>
    {% endfor %}
  </table>
</div>

<div class="footer">
  <p>Generated by <strong>OWASP WSTG Bug Bounty Framework</strong> | github.com/scp2801/owaspwstg-framework</p>
  <p>⚠️ For authorized security testing only.</p>
</div>
</body>
</html>
